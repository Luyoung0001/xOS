# ============================================================================
# mylibc/Makefile - 使用 common.mk 编译引擎
# ============================================================================
#
# mylibc - 嵌入式系统的 libc 子集
#
# 提供标准 C 库函数：
#   - stdio.h:  printf, sprintf, snprintf, putchar, puts
#   - string.h: strlen, strcpy, strcat, strcmp, memcpy, memset, ...
#   - ctype.h:  isdigit, isalpha, toupper, tolower, ...
#   - stdlib.h: atoi, strtol, abs, ...
#
# ============================================================================

# 定义库名
LIB_NAME := libmylibc.a

# 源文件会自动从 src/ 目录收集

# 包含编译引擎
include ../scripts/common.mk
